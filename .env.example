# ALARM_OFFSET_MINUTES=2
# RETRY_ATTEMPTS=3

# Device Configuration (override defaults)
# DEVICE_NAME=Samsung Galaxy S23
# PLATFORM_VERSION=13.0

# Logging
# LOG_LEVEL=info
# ENABLE_DEBUG=false
